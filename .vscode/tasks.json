{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Tickdrant",
            "type": "shell",
            "command": "xcodebuild",
            "args": [
                "-project",
                "Tickdrant.xcodeproj",
                "-scheme",
                "Tickdrant",
                "-configuration",
                "Debug",
                "build",
                "SYMROOT=${workspaceFolder}/build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build and Run",
            "type": "shell",
            "command": "./run.sh",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
